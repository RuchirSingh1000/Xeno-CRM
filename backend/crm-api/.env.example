# CRM API environment configuration

# Database: local sqlite for dev, Postgres URL for prod
DATABASE_URL=sqlite:///./crm.db
# DATABASE_URL=postgresql+psycopg://USER:PASS@HOST:5432/DBNAME

# Channel simulator base URL (the other service)
CHANNEL_SERVICE_URL=http://localhost:8001

# Shared HMAC secret used for webhook signing between simulator and CRM
WEBHOOK_HMAC_SECRET=dev-shared-secret-change-me

# LLM provider: anthropic | openai | gemini | groq | stub
# (If primary fails — rate limit, auth, network — the client transparently
#  retries against Groq if GROQ_API_KEY is set. So Groq doubles as universal fallback.)
LLM_PROVIDER=stub
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
LLM_MODEL_ANTHROPIC=claude-sonnet-4-6
LLM_MODEL_OPENAI=gpt-4o-mini
LLM_MODEL_GEMINI=gemini-2.5-flash
LLM_MODEL_GROQ=openai/gpt-oss-120b

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# App
APP_ENV=local
APP_PORT=8000
